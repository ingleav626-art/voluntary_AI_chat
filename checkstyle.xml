<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Checkstyle 配置文件 - 遵循阿里巴巴 Java 开发手册
    https://checkstyle.org/checks.html
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- 文件长度限制 -->
    <module name="FileLength">
        <property name="max" value="1500"/>
    </module>

    <!-- 禁止Tab字符 -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- 末尾换行 -->
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf_cr_crlf"/>
    </module>

    <!-- 行长度限制 -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- 禁止使用 System.out.println -->
    <module name="RegexpSingleline">
        <property name="format" value="System\.out\.print"/>
        <property name="message" value="请使用 Logger 替代 System.out.println"/>
    </module>

    <!-- 禁止使用 System.exit -->
    <module name="RegexpSingleline">
        <property name="format" value="System\.exit"/>
        <property name="message" value="禁止使用 System.exit"/>
    </module>

    <module name="TreeWalker">
        <!-- ==================== 命名规范 ==================== -->

        <!-- 类名：UpperCamelCase -->
        <module name="TypeName">
            <message key="name.invalidPattern"
                     value="类名 '{0}' 必须使用 UpperCamelCase 命名（允许中文）"/>
        </module>

        <!-- 方法名：lowerCamelCase -->
        <module name="MethodName">
            <message key="name.invalidPattern"
                     value="方法名 '{0}' 必须使用 lowerCamelCase 命名"/>
        </module>

        <!-- 参数名：lowerCamelCase -->
        <module name="ParameterName">
            <message key="name.invalidPattern"
                     value="参数名 '{0}' 必须使用 lowerCamelCase 命名"/>
        </module>

        <!-- 局部变量名：lowerCamelCase -->
        <module name="LocalVariableName">
            <message key="name.invalidPattern"
                     value="局部变量名 '{0}' 必须使用 lowerCamelCase 命名"/>
        </module>

        <!-- 成员变量名：lowerCamelCase -->
        <module name="MemberName">
            <message key="name.invalidPattern"
                     value="成员变量名 '{0}' 必须使用 lowerCamelCase 命名"/>
        </module>

        <!-- 常量名：UPPER_SNAKE_CASE -->
        <module name="ConstantName"/>
        <!-- 包名：全小写 -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- ==================== 导入规范 ==================== -->

        <!-- 禁止未使用的导入 -->
        <module name="UnusedImports"/>
        <!-- 禁止星号导入 -->
        <module name="AvoidStarImport"/>
        <!-- 导入顺序：静态导入在前，普通导入在后 -->
        <module name="CustomImportOrder">
            <property name="sortImportsInGroupAlphabetically" value="true"/>
            <property name="separateLineBetweenGroups" value="true"/>
            <property name="customImportOrderRules"
                      value="STATIC###STANDARD_JAVA_PACKAGE###THIRD_PARTY_PACKAGE"/>
        </module>

        <!-- ==================== 代码规范 ==================== -->

        <!-- 大括号位置：K&R 风格 -->
        <module name="LeftCurly"/>
        <module name="RightCurly"/>
        <module name="NeedBraces"/>

        <!-- 缩进：4个空格 -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="arrayInitIndent" value="4"/>
        </module>

        <!-- 禁止多余空格 -->
        <module name="NoWhitespaceAfter"/>
        <module name="NoWhitespaceBefore"/>
        <module name="GenericWhitespace"/>
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
        </module>

        <!-- ==================== 编程规范 ==================== -->

        <!-- 禁止魔法数字 -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="0,1,-1"/>
            <property name="ignoreAnnotationElementDefaults" value="true"/>
            <property name="ignoreFieldDeclaration" value="true"/>
        </module>

        <!-- 禁止空语句 -->
        <module name="EmptyStatement"/>

        <!-- 禁止重复导入 -->
        <module name="RedundantImport"/>

        <!-- 必须使用 final 修饰不可变参数 -->
        <module name="FinalParameters"/>

        <!-- 方法长度限制 -->
        <module name="MethodLength">
            <property name="max" value="80"/>
            <property name="countEmpty" value="false"/>
        </module>

        <!-- 方法参数数量限制 -->
        <module name="ParameterNumber">
            <property name="max" value="5"/>
            <property name="ignoreOverriddenMethods" value="true"/>
        </module>

        <!-- ==================== 异常处理 ==================== -->

        <!-- 禁止捕获通用异常 -->
        <module name="IllegalCatch">
            <property name="illegalClassNames" value="java.lang.Exception,java.lang.Throwable"/>
        </module>

        <!-- 禁止使用 finalize -->
        <module name="NoFinalizer"/>
    </module>
</module>

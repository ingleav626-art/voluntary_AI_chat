<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" prefHeight="500.0" prefWidth="520.0"
      spacing="10.0" styleClass="ai-dialog-root"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controller.GroupAiConfigController">

    <Label fx:id="dialogTitle" styleClass="ai-dialog-title" text="群 AI 配置"/>

    <!-- 已有配置列表 -->
    <VBox spacing="6.0" VBox.vgrow="ALWAYS">
        <Label text="已配置的 AI" styleClass="ai-form-label"/>
        <ListView fx:id="configListView" prefHeight="180.0" styleClass="ai-config-list"/>
    </VBox>

    <!-- 新增/编辑配置表单 -->
    <VBox spacing="8.0" styleClass="ai-dialog-form">
        <Label fx:id="formTitle" text="添加 AI 配置" styleClass="ai-form-label"/>

        <!-- AI 选择 -->
        <VBox spacing="4.0">
            <Label text="选择 AI 角色 *" styleClass="ai-form-label"/>
            <ComboBox fx:id="aiSelectCombo" promptText="选择 AI 角色"
                      styleClass="ai-form-combo" maxWidth="Infinity"/>
        </VBox>

        <!-- 触发关键词 -->
        <VBox spacing="4.0">
            <Label text="触发关键词（逗号分隔）" styleClass="ai-form-label"/>
            <TextField fx:id="triggerKeywordsField" promptText="例如：小助手,AI,助手"
                       styleClass="ai-form-input"/>
        </VBox>

        <!-- 触发概率 + 冷却时间 -->
        <HBox spacing="15.0">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label text="触发概率 (0.0-1.0)" styleClass="ai-form-label"/>
                <TextField fx:id="triggerProbabilityField" promptText="0.10"
                           styleClass="ai-form-input"/>
            </VBox>
        </HBox>

        <!-- 启用开关 -->
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <CheckBox fx:id="isEnabledCheck" text="启用此配置" selected="true"/>
        </HBox>
    </VBox>

    <!-- 底部按钮 -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="ai-dialog-footer">
        <Label fx:id="errorLabel" styleClass="error-message" text=""/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="cancelButton" mnemonicParsing="false"
                onAction="#handleCancel" styleClass="btn-icon" text="关闭"/>
        <Button fx:id="addButton" mnemonicParsing="false"
                onAction="#handleAdd" styleClass="btn-primary" text="添加配置"/>
    </HBox>
</VBox>

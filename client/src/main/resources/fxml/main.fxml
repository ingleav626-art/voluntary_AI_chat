<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane fx:id="rootPane" prefHeight="700.0" prefWidth="1000.0"
            styleClass="main-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controller.MainController">

    <!-- 左侧：用户信息 + 会话列表 -->
    <left>
        <VBox prefWidth="280.0" minWidth="280.0" maxWidth="280.0" styleClass="sidebar">
            <!-- 用户信息卡片 -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="user-card">
                <Circle fx:id="avatarCircle" fill="#42A5F5" radius="20.0"/>
                <Label fx:id="avatarText" styleClass="avatar-text" text="张"/>
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="usernameLabel" styleClass="username-label" text="用户名"/>
                    <HBox spacing="5.0">
                        <Circle fx:id="statusDot" fill="#9E9E9E" radius="4.0"/>
                        <Label fx:id="statusLabel" styleClass="status-label" text="离线"/>
                    </HBox>
                </VBox>
                <Button fx:id="settingsButton" mnemonicParsing="false"
                        onAction="#handleSettings" styleClass="btn-icon" text="设置"/>
            </HBox>

            <Separator/>

            <!-- AI 助手入口 -->
            <Button fx:id="aiButton" mnemonicParsing="false"
                    onAction="#handleAi" styleClass="btn-ai-entry" text="AI 助手" maxWidth="Infinity"/>

            <Separator/>

            <!-- 搜索框 -->
            <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="search-box">
                <Label text="🔍" styleClass="search-icon"/>
                <TextField fx:id="searchField" promptText="搜索会话" styleClass="search-input" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- 会话列表 -->
            <ListView fx:id="conversationList" styleClass="conversation-list" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="暂无会话"/>
                </placeholder>
            </ListView>

            <!-- 底部操作栏 -->
            <VBox spacing="6.0" styleClass="sidebar-footer">
                <HBox alignment="CENTER" spacing="12.0" HBox.hgrow="ALWAYS">
                    <Button fx:id="friendButton" mnemonicParsing="false"
                            onAction="#handleFriend" styleClass="btn-icon" text="好友" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="groupButton" mnemonicParsing="false"
                            onAction="#handleGroup" styleClass="btn-icon" text="群聊" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox alignment="CENTER" spacing="12.0" HBox.hgrow="ALWAYS">
                    <Button fx:id="logoutButton" mnemonicParsing="false"
                            onAction="#handleLogout" styleClass="btn-logout" text="退出登录" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- 右侧：聊天区域 -->
    <center>
        <VBox styleClass="chat-area">
            <!-- 聊天标题栏 -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="chat-header">
                <Label fx:id="chatTitleLabel" styleClass="chat-title" text="请选择会话"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="connectionLabel" styleClass="connection-label" text=""/>
            </HBox>

            <Separator/>

            <!-- 消息列表 -->
            <ListView fx:id="messageList" styleClass="message-list" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="暂无消息，开始聊天吧"/>
                </placeholder>
            </ListView>

            <Separator/>

            <!-- 输入区域 -->
            <VBox fx:id="inputAreaContainer" styleClass="input-area">
                <!-- 工具栏：+ 按钮（发送图片 / 发送文件） -->
                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="input-toolbar">
                    <Button fx:id="plusButton" mnemonicParsing="false"
                            onAction="#handlePlusButton" style="-fx-background-color: #FFE8D6; -fx-text-fill: #E76F51; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-min-width: 36px; -fx-min-height: 36px; -fx-alignment: center; -fx-cursor: hand; -fx-border-color: transparent;" text="+"/>
                </HBox>
                <!-- 输入框 -->
                <TextArea fx:id="inputArea" promptText="输入消息... (Enter 发送, Shift+Enter 换行)"
                          styleClass="input-textarea" wrapText="true"
                          prefRowCount="3" maxWidth="Infinity"
                          onKeyPressed="#handleInputKeyPress"/>
                <!-- 底部：错误提示 + 发送按钮 -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="input-footer">
                    <Label fx:id="errorLabel" styleClass="error-message" text=""/>
                    <Button fx:id="sendButton" mnemonicParsing="false"
                            onAction="#handleSend" styleClass="btn-send" text="发送"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>

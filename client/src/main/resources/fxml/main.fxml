<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" prefHeight="700.0" prefWidth="1000.0"
            styleClass="main-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controller.MainController">

    <!-- 顶部：全局标题栏 -->
    <top>
        <fx:include fx:id="topBar" source="top_bar.fxml"/>
    </top>

    <!-- 主体：三栏布局 -->
    <center>
        <HBox styleClass="main-body">

            <!-- 第一栏：功能侧边栏（固定60px，毛玻璃底色） -->
            <fx:include fx:id="functionBar" source="function_bar.fxml"/>

            <!-- 第二栏：会话列表区（浅灰底色，可隐藏） -->
            <VBox fx:id="conversationPanel" prefWidth="260.0" minWidth="200.0" maxWidth="320.0"
                  styleClass="conversation-panel">
                <!-- 会话列表 -->
                <ListView fx:id="conversationList" styleClass="conversation-list" VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="暂无会话"/>
                    </placeholder>
                </ListView>
            </VBox>

            <!-- 第三栏：聊天内容窗口（纯白底色） -->
            <VBox styleClass="chat-area" HBox.hgrow="ALWAYS">
                <!-- 聊天标题栏 -->
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="chat-header">
                    <Label fx:id="chatTitleLabel" styleClass="chat-title" text="请选择会话"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="connectionLabel" styleClass="connection-label" text=""/>
                </HBox>

                <!-- 消息列表 -->
                <ListView fx:id="messageList" styleClass="message-list" VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="暂无消息，开始聊天吧"/>
                    </placeholder>
                </ListView>

                <!-- 输入区域 -->
                <VBox fx:id="inputAreaContainer" styleClass="input-area">
                    <!-- 工具栏：+ 按钮 -->
                    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="input-toolbar">
                        <Button fx:id="plusButton" mnemonicParsing="false"
                                onAction="#handlePlusButton" styleClass="btn-tool" text="+"/>
                    </HBox>
                    <!-- 输入框 -->
                    <TextArea fx:id="inputArea" promptText="输入消息... (Enter 发送, Shift+Enter 换行)"
                              styleClass="input-textarea" wrapText="true"
                              prefRowCount="3" maxWidth="Infinity"
                              onKeyPressed="#handleInputKeyPress"/>
                    <!-- 底部：错误提示 + 发送按钮 -->
                    <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="input-footer">
                        <Label fx:id="errorLabel" styleClass="error-message" text=""/>
                        <Button fx:id="sendButton" mnemonicParsing="false"
                                onAction="#handleSend" styleClass="btn-send" text="发送"/>
                    </HBox>
                </VBox>
            </VBox>

        </HBox>
    </center>
</BorderPane>

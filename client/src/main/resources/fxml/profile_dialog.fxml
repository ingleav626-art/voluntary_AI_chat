<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.SpinnerValueFactory.IntegerSpinnerValueFactory?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
      minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="580.0" prefWidth="450.0" spacing="10.0"
      styleClass="dialog-container"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controller.ProfileController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- 标题 -->
    <Label styleClass="dialog-title" text="个人设置"/>

    <!-- TabPane -->
    <TabPane fx:id="tabPane" prefHeight="400.0" prefWidth="420.0" tabClosingPolicy="UNAVAILABLE">

        <!-- 基本信息 Tab -->
        <Tab text="基本信息">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <VBox spacing="12.0" styleClass="tab-content">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
                    </padding>

                <!-- 头像区域 -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <StackPane>
                        <Circle fx:id="avatarCircle" fill="#e0e0e0" radius="40.0"/>
                    </StackPane>
                    <Button fx:id="changeAvatarButton" text="更换头像" styleClass="btn-secondary"
                            onAction="#handleChangeAvatar"/>
                </HBox>

                <!-- 用户名 -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="用户名:" prefWidth="80.0"/>
                    <TextField fx:id="usernameField" promptText="用户名（2-50字符）" prefWidth="280.0"/>
                </HBox>

                <!-- 手机号（只读） -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="手机号:" prefWidth="80.0"/>
                    <TextField fx:id="phoneField" editable="false" prefWidth="280.0" styleClass="readonly-field"/>
                </HBox>

                <!-- 个人简介 -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="简介:" prefWidth="80.0"/>
                    <TextField fx:id="bioField" promptText="个人简介" prefWidth="280.0"/>
                </HBox>

                <!-- 性别 -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="性别:" prefWidth="80.0"/>
                    <ComboBox fx:id="genderComboBox" prefWidth="280.0"/>
                </HBox>

                <!-- 年龄 -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="年龄:" prefWidth="80.0"/>
                    <Spinner fx:id="ageSpinner" prefWidth="280.0">
                        <valueFactory>
                            <SpinnerValueFactory.IntegerSpinnerValueFactory min="0" max="200" initialValue="0"/>
                        </valueFactory>
                    </Spinner>
                </HBox>

                <!-- 生日 -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="生日:" prefWidth="80.0"/>
                    <DatePicker fx:id="birthdayPicker" prefWidth="280.0" promptText="选择生日"/>
                </HBox>

                <!-- 详细说明 -->
                <VBox spacing="5.0">
                    <Label text="详细说明:"/>
                    <TextArea fx:id="detailBioArea" promptText="个人详细说明（最多2000字符）"
                              prefHeight="150.0" prefWidth="370.0" wrapText="true"/>
                </VBox>

                <!-- 注册时间（只读） -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="注册时间:" prefWidth="80.0"/>
                    <Label fx:id="createTimeLabel" text="-" styleClass="info-label"/>
                </HBox>

                <!-- 消息提示 -->
                <Label fx:id="profileMessageLabel" styleClass="message-label" text=""/>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- 账号安全 Tab -->
        <Tab text="账号安全">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <VBox spacing="15.0" styleClass="tab-content">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
                    </padding>

                    <!-- 修改密码区域 -->
                    <VBox spacing="10.0" styleClass="section-box">
                        <Label text="修改密码" styleClass="section-title"/>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="当前手机:" prefWidth="80.0"/>
                            <Label fx:id="passwordPhoneLabel" text="-" styleClass="info-label"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Button fx:id="sendPasswordSmsButton" text="发送验证码" styleClass="btn-secondary"
                                    onAction="#handleSendPasswordSms"/>
                            <TextField fx:id="passwordSmsField" promptText="6位验证码" prefWidth="150.0"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="新密码:" prefWidth="80.0"/>
                            <PasswordField fx:id="newPasswordField" promptText="新密码（6-50字符）" prefWidth="280.0"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="确认密码:" prefWidth="80.0"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="确认密码" prefWidth="280.0"/>
                        </HBox>

                        <StackPane>
                            <Button fx:id="changePasswordButton" text="确认修改" styleClass="btn-primary"
                                    prefWidth="120.0" onAction="#handleChangePassword"/>
                            <ProgressIndicator fx:id="passwordLoadingIndicator" prefHeight="20.0" prefWidth="20.0"
                                               visible="false"/>
                        </StackPane>
                    </VBox>

                    <!-- 修改手机号区域 -->
                    <VBox spacing="10.0" styleClass="section-box">
                        <Label text="修改手机号" styleClass="section-title"/>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="当前手机:" prefWidth="80.0"/>
                            <Label fx:id="changePhoneLabel" text="-" styleClass="info-label"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Button fx:id="sendCurrentSmsButton" text="发送验证码" styleClass="btn-secondary"
                                    onAction="#handleSendCurrentSms"/>
                            <TextField fx:id="currentSmsField" promptText="当前验证码" prefWidth="150.0"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="新手机号:" prefWidth="80.0"/>
                            <TextField fx:id="newPhoneField" promptText="新手机号" prefWidth="280.0"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Button fx:id="sendNewSmsButton" text="发送验证码" styleClass="btn-secondary"
                                    onAction="#handleSendNewSms"/>
                            <TextField fx:id="newSmsField" promptText="新验证码" prefWidth="150.0"/>
                        </HBox>

                        <StackPane>
                            <Button fx:id="changePhoneButton" text="确认修改" styleClass="btn-primary"
                                    prefWidth="120.0" onAction="#handleChangePhone"/>
                            <ProgressIndicator fx:id="phoneLoadingIndicator" prefHeight="20.0" prefWidth="20.0"
                                               visible="false"/>
                        </StackPane>
                    </VBox>

                    <!-- 消息提示 -->
                    <Label fx:id="securityMessageLabel" styleClass="message-label" text=""/>
                </VBox>
            </ScrollPane>
        </Tab>
    </TabPane>

    <!-- 保存按钮 -->
    <HBox alignment="CENTER">
        <StackPane>
            <Button fx:id="saveProfileButton" text="保存修改" styleClass="btn-primary"
                    prefWidth="150.0" onAction="#handleSaveProfile"/>
            <ProgressIndicator fx:id="profileLoadingIndicator" prefHeight="20.0" prefWidth="20.0"
                               visible="false"/>
        </StackPane>
    </HBox>
</VBox>